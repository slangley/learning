# .env.example — copy this file to skills/.env and fill in your values
# NEVER commit skills/.env to source control.

# Required: ElevenLabs API key
# Get one at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Required: S3 bucket name to upload podcasts to
S3_BUCKET=your-bucket-name-here

# Optional: key prefix (folder) inside the bucket (default: podcasts/)
S3_PREFIX=podcasts/

# AWS credentials — if not set here, boto3 falls back to ~/.aws/credentials or IAM role
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
