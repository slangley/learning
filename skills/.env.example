# .env.example — copy this file to skills/.env and fill in your values
# NEVER commit skills/.env to source control.

# Required: Dropbox API access token
# Get one at https://www.dropbox.com/developers/apps
DROPBOX_ACCESS_TOKEN=your_dropbox_access_token_here

# Optional: destination folder inside your Dropbox (default: /Podcasts)
DROPBOX_FOLDER=/Podcasts
